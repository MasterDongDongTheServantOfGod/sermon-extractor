# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Gemini (for sermon summarization)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI (for article writing + risk review)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Supadata (optional transcript fallback)
SUPADATA_API_KEY=

# Vercel serverless defaults
CANDIDATE_LIMIT=8
PARALLEL_LIMIT=2
SUPADATA_FALLBACK_COUNT=2
YOUTUBE_COLLECT_MAX_RESULTS=8
TRANSCRIPT_SCAN_LIMIT=8

# YouTube cookies.txt, base64-encoded for deployment env vars (optional)
YT_COOKIES_BASE64=

# Database (required in all environments; use Postgres/Supabase on Vercel)
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres
