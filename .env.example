# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Gemini (for sermon summarization)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI (for article writing + risk review)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Supadata (optional transcript fallback)
SUPADATA_API_KEY=

# YouTube cookies.txt, base64-encoded for Render env vars (optional)
YT_COOKIES_BASE64=

# Database (default: SQLite)
DATABASE_URL=sqlite:///./sermon.db
